# Anthropic Claude API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database Configuration (optional - defaults to SQLite)
# DATABASE_URL=sqlite:///./listing_agent.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/listing_agent

# eBay API Configuration
# Get your credentials at: https://developer.ebay.com/
EBAY_ENV=SANDBOX  # SANDBOX or PRODUCTION
EBAY_CLIENT_ID=your_ebay_client_id_here
EBAY_CLIENT_SECRET=your_ebay_client_secret_here
EBAY_REDIRECT_URI=http://localhost:3000/ebay/callback
EBAY_RU_NAME=your_ebay_runame_here

# eBay Business Policies (optional - can be created in eBay Seller Hub)
# These are the IDs for your default shipping, return, and payment policies
# You can create these at: https://www.ebay.com/sh/ovw
EBAY_DEFAULT_SHIPPING_POLICY_ID=
EBAY_DEFAULT_RETURN_POLICY_ID=
EBAY_DEFAULT_PAYMENT_POLICY_ID=

# Learning System Configuration (optional)
# Minimum number of analyses required before creating a learned product
MIN_ANALYSES_FOR_LEARNING=3

# Confidence thresholds for learned data usage
CONFIDENCE_THRESHOLD_HIGH=0.7  # Skip AI API call if confidence >= this
CONFIDENCE_THRESHOLD_MED=0.3   # Use hybrid mode (verify with AI) if confidence >= this

# How often to aggregate analyses into learned products (every N confirmations)
AGGREGATION_TRIGGER=10

# Image similarity threshold for perceptual hashing (0-64, lower = more similar)
IMAGE_SIMILARITY_THRESHOLD=5

# Server Configuration (optional)
PORT=8000
HOST=0.0.0.0

# IMPORTANT: API_BASE_URL must be an HTTPS URL for eBay image uploads to work
# Use ngrok or localtunnel to expose your local server via HTTPS:
#   Option 1 (localtunnel): lt --port 8000 --subdomain your-subdomain
#   Option 2 (ngrok): ngrok http 8000
# Then set API_BASE_URL to the HTTPS URL provided by the tunnel
API_BASE_URL=http://localhost:8000  # For local development only
# API_BASE_URL=https://your-subdomain.loca.lt  # Example with localtunnel
# API_BASE_URL=https://your-subdomain.ngrok.io  # Example with ngrok

# Logging Configuration (optional)
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Cost Estimation (optional)
ESTIMATED_COST_PER_API_CALL=0.01  # USD per Claude API call for analytics
